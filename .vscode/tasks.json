{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "windows": {
                "command": "sh build.sh"
            },
            "linux": {
                "command": "./build.sh",
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Build Debug",
            "type": "shell",
            "windows": {
                "command": "sh build.sh debug"
            },
            "linux": {
                "command": "./build.sh debug",
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}